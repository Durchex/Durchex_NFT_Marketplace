# MongoDB Atlas Configuration
# Replace placeholders with your real MongoDB Atlas values.
# IMPORTANT: Do NOT commit real credentials to git. Rotate any exposed password immediately.
# If your backend code reads `process.env.DATABASE` (see backend/config/dbConfig.ts), set DATABASE below.
# Example (replace <user>, <password>, <cluster-url>, <dbname> accordingly):
# DATABASE=mongodb+srv://<user>:<password>@<cluster-url>/<dbname>?retryWrites=true&w=majority
# If you prefer a different env var name (MONGO_URI or MONGODB_URI), add it here as well.

# Put your actual connection string here (no quotes):
PORT=3001
DATABASE=mongodb+srv://durchex_db_user:Durchex2026@durchex-cluster.otgf1xa.mongodb.net/?appName=durchex-cluster

# Pinata IPFS — get keys from https://app.pinata.cloud/keys
# These are used by the backend to proxy IPFS uploads. Never shared with the browser.
PINATA_API_KEY=
PINATA_SECRET_KEY=

MONGO_URI=mongodb+srv://durchex_db_user:Durchex2026@durchex-cluster.otgf1xa.mongodb.net/?appName=durchex-cluster
MONGODB_URI=mongodb+srv://durchex_db_user:Durchex2026@durchex-cluster.otgf1xa.mongodb.net/?appName=durchex-cluster

# Server Configuration
# PORT=3000
NODE_ENV=development

# Smart Contract Addresses (update with your deployed contracts)
VITE_APP_NFTMARKETPLACE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_APP_VENDORNFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Backend URL for frontend
VITE_APP_BACKEND_URL=http://durchex.com/api/v1

# Web3 Provider (optional)
VITE_APP_WEB3_PROVIDER=https://ethereum-sepolia.core.chainstack.com/390cec07d0dbe1818b3bb25db398c3ca

# SIU network placeholders
SIU_CHAIN_ID=
SIU_RPC_URL=
SIU_BLOCK_EXPLORER=
SIU_MARKETPLACE_CONTRACT_ADDRESS=
SIU_VENDOR_NFT_CONTRACT_ADDRESS=

# Base network placeholders
BASE_CHAIN_ID=
BASE_RPC_URL=
BASE_BLOCK_EXPLORER=
BASE_MARKETPLACE_CONTRACT_ADDRESS=
BASE_VENDOR_NFT_CONTRACT_ADDRESS=

# Monarch network placeholders
MONARCH_CHAIN_ID=
MONARCH_RPC_URL=
MONARCH_BLOCK_EXPLORER=
MONARCH_MARKETPLACE_CONTRACT_ADDRESS=
MONARCH_VENDOR_NFT_CONTRACT_ADDRESS=

# Rate limiter defaults (can override)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
