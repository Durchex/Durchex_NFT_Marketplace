# API
VITE_API_BASE_URL=https://your-api.com/api/v1

# WalletConnect (for mobile wallet QR scanning)
# Get from https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

PRIVATE_KEY=Your deployer wallet private key

PLATFORM_FEE_RECEIVER=0xYourPlatformFeeReceiverAddress
# Contract Addresses - Generated on [timestamp]
VITE_APP_LAZY_MINT_CONTRACT_ADDRESS=0xDefaultMultiPieceLazyMintAddress

# Multi-piece lazy mint contracts (per-network)
VITE_APP_MULTI_LAZY_MINT_CONTRACT_ADDRESS_ETHEREUM=0x...
VITE_APP_MULTI_LAZY_MINT_CONTRACT_ADDRESS_POLYGON=0x...
VITE_APP_MULTI_LAZY_MINT_CONTRACT_ADDRESS_BSC=0x...
VITE_APP_MULTI_LAZY_MINT_CONTRACT_ADDRESS_ARBITRUM=0x...
